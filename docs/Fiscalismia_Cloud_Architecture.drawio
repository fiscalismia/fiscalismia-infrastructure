        <mxCell id="UnEULMIhb13hHUrPRZhk-1" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;fontColor=light-dark(#41cb00, #446e2c);strokeColor=#666666;fontFamily=Helvetica;snapToPoint=0;fixDash=0;" value="" vertex="1">
          <mxGeometry height="439.5" width="700" x="2570.2" y="719.5" as="geometry" />
        </mxCell>
        <mxCell id="UnEULMIhb13hHUrPRZhk-2" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontStyle=0;fontSize=16;align=center;fillColor=#d5e8d4;strokeColor=#82b366;fontFamily=Helvetica;labelBorderColor=none;snapToPoint=0;fixDash=0;" value="AWS Infrastructure Killswitch" vertex="1">
          <mxGeometry height="40" width="290" x="2280.2" y="719.5" as="geometry" />
        </mxCell>
        <mxCell id="UnEULMIhb13hHUrPRZhk-3" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontStyle=0;fontSize=14;align=left;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;fontFamily=Helvetica;snapToPoint=0;fixDash=0;" value="&lt;u&gt;&lt;b&gt;Workflow&lt;/b&gt;:&lt;/u&gt;&lt;br&gt;&lt;div&gt;&lt;b&gt;1.)&lt;/b&gt;&amp;nbsp;AWS Budget updates every 8-12 hours to continuously monitor Actual Costs accrued&lt;/div&gt;&lt;div&gt;&lt;b style=&quot;background-color: transparent; color: light-dark(rgb(51, 51, 51), rgb(193, 193, 193));&quot;&gt;2.)&lt;/b&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(51, 51, 51), rgb(193, 193, 193));&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(51, 51, 51), rgb(193, 193, 193));&quot;&gt;AWS Budget&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(51, 51, 51), rgb(193, 193, 193));&quot;&gt;hits BudgetLimitExceeded SNS Topic if Actual Cost Threshold in USD is surpassed&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;b style=&quot;background-color: transparent; color: light-dark(rgb(51, 51, 51), rgb(193, 193, 193));&quot;&gt;3.)&lt;/b&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(51, 51, 51), rgb(193, 193, 193));&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;BudgetLimitExceededAction SNS Topic invokes the&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;TerraformModuleDestroyer Lambda Function&lt;br&gt;&lt;/span&gt;&lt;b style=&quot;color: light-dark(rgb(51, 51, 51), rgb(193, 193, 193)); background-color: transparent;&quot;&gt;4.)&lt;/b&gt;&lt;span style=&quot;color: light-dark(rgb(51, 51, 51), rgb(193, 193, 193)); background-color: transparent;&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(51, 51, 51), rgb(193, 193, 193));&quot;&gt;TerraformDestroyTrigger&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(51, 51, 51), rgb(193, 193, 193));&quot;&gt;&amp;nbsp;Lambda Function Invokes Github API WebRequest to start TerraformModuleDestroyer pipeline&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;b style=&quot;background-color: transparent; color: light-dark(rgb(51, 51, 51), rgb(193, 193, 193));&quot;&gt;5.)&lt;/b&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(51, 51, 51), rgb(193, 193, 193));&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(51, 51, 51), rgb(193, 193, 193));&quot;&gt;TerraformModuleDestroyer&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(51, 51, 51), rgb(193, 193, 193));&quot;&gt;&amp;nbsp; pipeline&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(51, 51, 51), rgb(193, 193, 193));&quot;&gt;destroys only Terraform modules without persistent state (keeps s3 buckets)&lt;/span&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(51, 51, 51), rgb(193, 193, 193));&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;b&gt;6.)&lt;/b&gt;&amp;nbsp;Throttling lambda then hits a SNS topic for notifying the admin with a throttling message&lt;/div&gt;&lt;div&gt;&lt;b&gt;7.)&lt;/b&gt;&amp;nbsp;ThrottlingNotification SNS topic invokes a generic notification Lambda with a message&lt;/div&gt;&lt;div&gt;&lt;b&gt;8.)&lt;/b&gt;&amp;nbsp;Notification Lambda takes a generic message and forwards it to the admin via a bot accesible via the telegram API&lt;br&gt;&lt;b&gt;9.)&lt;/b&gt;&amp;nbsp;User receives Bot Notification Message&lt;/div&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="399.5" width="290" x="2280.2" y="759.5" as="geometry" />
        </mxCell>
