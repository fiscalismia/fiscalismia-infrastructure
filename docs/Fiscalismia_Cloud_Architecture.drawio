        <mxCell id="2dqsXh7Py2JDM5GBmdY1-7" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fad7ac;strokeColor=#b46504;fontStyle=1;shadow=0;" value="security-evaluation-hcloud" vertex="1">
          <mxGeometry height="40" width="389.75" x="2745.25" y="2799" as="geometry" />
        </mxCell>
        <mxCell id="2dqsXh7Py2JDM5GBmdY1-8" parent="1" style="rounded=0;html=1;align=left;verticalAlign=top;fillColor=#f5f5f5;fontColor=#333333;strokeColor=#666666;absoluteArcSize=0;shadow=0;spacing=0;whiteSpace=wrap;miterlimit=4;labelBackgroundColor=none;textShadow=0;" value="&lt;div&gt;&lt;font color=&quot;#000000&quot;&gt;&amp;nbsp; &lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;u&gt;Overview:&lt;/u&gt;&lt;/font&gt;&lt;/font&gt;&lt;/div&gt;&lt;ul&gt;&lt;li&gt;&lt;font color=&quot;#000000&quot;&gt;is manually triggered on-demand&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font color=&quot;#000000&quot;&gt;utilizes a network-sentinel instance to probe the entire network with portscans for ingress firewall evaluation&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font color=&quot;#000000&quot;&gt;utilizes ssh-agent to connect to all instances within hetzner for egress firewall evaluation&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font color=&quot;#000000&quot;&gt;uses custom bash-scripts with network monitoring tools such as ncat, nmap and can do full portscans from 1-65536&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;font color=&quot;#000000&quot;&gt;&amp;nbsp;&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;u&gt;Steps:&lt;/u&gt;&lt;/font&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;&lt;font color=&quot;#000000&quot;&gt;&lt;font&gt;Checks out Source Code&lt;/font&gt;&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font color=&quot;#000000&quot;&gt;&lt;font style=&quot;&quot;&gt;Configure AWS Credentials with OIDC JWT Token for STS Access to Hcloud Backend Role&lt;/font&gt;&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font color=&quot;#000000&quot;&gt;&lt;font style=&quot;&quot;&gt;Query SSH private keys for Hcloud servers from AWS Secrets Manager&lt;/font&gt;&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font color=&quot;#000000&quot;&gt;&lt;font style=&quot;&quot;&gt;Extract Hcloud Server IP Adresses from Remote State&lt;/font&gt;&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font color=&quot;#000000&quot;&gt;&lt;font style=&quot;&quot;&gt;Create SSH Config for Bastion-Host ProxyJump&lt;/font&gt;&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font color=&quot;#000000&quot;&gt;&lt;font style=&quot;&quot;&gt;Generating Private IPV4 Targets for Port Scanning&lt;/font&gt;&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font color=&quot;#000000&quot;&gt;&lt;font style=&quot;&quot;&gt;Security Evaluation of Loadbalancer&lt;/font&gt;&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font color=&quot;#000000&quot;&gt;&lt;font style=&quot;&quot;&gt;Security Evaluation of Bastion-Host&lt;/font&gt;&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font color=&quot;#000000&quot;&gt;&lt;font style=&quot;&quot;&gt;Private Ingress Security Evaluation via Network Sentinel&lt;/font&gt;&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font color=&quot;#000000&quot;&gt;&lt;font style=&quot;&quot;&gt;...&lt;/font&gt;&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font color=&quot;#000000&quot;&gt;&lt;font style=&quot;&quot;&gt;...&lt;/font&gt;&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font color=&quot;#000000&quot;&gt;&lt;font style=&quot;&quot;&gt;...&lt;/font&gt;&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" vertex="1">
