        <mxCell id="xqXAjq9A-HITpdVLmNYo-190" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f5f5f5;fontColor=light-dark(#41cb00, #446e2c);strokeColor=#666666;fontFamily=Helvetica;snapToPoint=0;fixDash=0;" value="" vertex="1">
          <mxGeometry height="420" width="700" x="2570.2" y="269" as="geometry" />
        </mxCell>
        <mxCell id="xqXAjq9A-HITpdVLmNYo-191" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontStyle=0;fontSize=16;align=center;fillColor=#d5e8d4;strokeColor=#82b366;fontFamily=Helvetica;labelBorderColor=none;snapToPoint=0;fixDash=0;" value="API Gateway Autoscaling DDos/Cost Protection" vertex="1">
          <mxGeometry height="40" width="290" x="2280.2" y="269" as="geometry" />
        </mxCell>
        <mxCell id="xqXAjq9A-HITpdVLmNYo-192" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontStyle=0;fontSize=14;align=left;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;fontFamily=Helvetica;snapToPoint=0;fixDash=0;" value="&lt;u&gt;&lt;b&gt;Workflow&lt;/b&gt;:&lt;/u&gt;&lt;br&gt;&lt;div&gt;&lt;b&gt;1.)&lt;/b&gt; Cloudwatch continuously monitors API Gateway invocations on a per-route basis for &quot;Count&quot; metric exceeding a set threshold&lt;/div&gt;&lt;div&gt;&lt;b&gt;2.)&lt;/b&gt;&amp;nbsp;On exceeding the threshold for 3 minutes consecutively, it triggers a cloudwatch metric alarm&lt;/div&gt;&lt;div&gt;&lt;b&gt;3.)&lt;/b&gt;&amp;nbsp;Cloudwatch alarm action hits a SNS topic&lt;/div&gt;&lt;div&gt;&lt;b&gt;4.)&lt;/b&gt;&amp;nbsp;Throttling SNS Topic invokes a throttling Lambda function with the route_key&amp;nbsp;&lt;/div&gt;&lt;div&gt;&lt;b&gt;5.)&lt;/b&gt;&amp;nbsp;Throttling lambda function sets the &quot;ThrottlingBurstLimit&quot; &amp;amp; &quot;ThrottlingRateLimit&quot; in the specific &quot;RouteSettings&quot; to 0.0&lt;/div&gt;&lt;div&gt;&lt;b&gt;6.)&lt;/b&gt;&amp;nbsp;Throttling lambda then hits a SNS topic for notifying the admin with a throttling message&lt;/div&gt;&lt;div&gt;&lt;b&gt;7.)&lt;/b&gt;&amp;nbsp;ThrottlingNotification SNS topic invokes a generic notification Lambda with a message&lt;/div&gt;&lt;div&gt;&lt;b&gt;8.)&lt;/b&gt;&amp;nbsp;Notification Lambda takes a generic message and forwards it to the admin via a bot accesible via the telegram API&lt;br&gt;&lt;b&gt;9.)&lt;/b&gt;&amp;nbsp;User receives Bot Notification Message&lt;/div&gt;" vertex="1">
          <mxGeometry height="380" width="290" x="2280.2" y="309" as="geometry" />
        </mxCell>
        <mxCell id="xqXAjq9A-HITpdVLmNYo-193" parent="1" style="sketch=0;outlineConnect=0;fontColor=#232F3E;gradientColor=none;strokeColor=#ffffff;fillColor=#232F3E;dashed=0;verticalLabelPosition=middle;verticalAlign=bottom;align=center;html=1;whiteSpace=wrap;fontSize=10;fontStyle=1;spacing=3;shape=mxgraph.aws4.productIcon;prIcon=mxgraph.aws4.api_gateway;fontFamily=Helvetica;snapToPoint=0;fixDash=0;" value="Public AWS&amp;nbsp; HTTP API Gateway" vertex="1">
