        <UserObject label="https://github.com/&#xa;fiscalismia/&#xa;fiscalismia-infrastructure/&#xa;actions/workflows/&#xa;infrastructure-deployment-pipeline.yml" id="F3hjLusn7BbRF5pgiLsR-2">
          <mxCell parent="1" style="text;whiteSpace=wrap;fontSize=14;shadow=0;" vertex="1">
            <mxGeometry height="111" width="159" x="1981" y="3788" as="geometry" />
          </mxCell>
        </UserObject>
        <mxCell id="F3hjLusn7BbRF5pgiLsR-3" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fad7ac;strokeColor=#b46504;fontStyle=1;shadow=0;" value="webservice-deployment" vertex="1">
          <mxGeometry height="40" width="389.75" x="2745.25" y="3688" as="geometry" />
        </mxCell>
        <mxCell id="F3hjLusn7BbRF5pgiLsR-4" parent="1" style="rounded=0;html=1;align=left;verticalAlign=top;fillColor=#f5f5f5;fontColor=#333333;strokeColor=#666666;absoluteArcSize=0;shadow=0;spacing=0;whiteSpace=wrap;miterlimit=4;labelBackgroundColor=none;textShadow=0;" value="&lt;div&gt;&lt;font color=&quot;#000000&quot;&gt;&amp;nbsp; &lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;u&gt;Overview:&lt;/u&gt;&lt;/font&gt;&lt;/font&gt;&lt;/div&gt;&lt;ul&gt;&lt;li&gt;&lt;font color=&quot;#000000&quot;&gt;is manually triggered on-demand to to Deploy either the application DEMO, FRONTEND and/or BACKEND instances on Hetzner Cloud via SSH commands to targets via Bastion-Host Instance ProxyJump&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font color=&quot;#000000&quot;&gt;In the case of the demo instance, the containers are built locally by secure copying all relevant files including the database initialization scripts from checked out repositories and running docker compose up --build&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;font color=&quot;#000000&quot;&gt;&amp;nbsp;&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;u&gt;Steps:&lt;/u&gt;&lt;/font&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;&lt;font color=&quot;#000000&quot;&gt;&lt;font&gt;Checks out Source Code from 1) Infrastructure 2) Frontend 3) Backend 4) Webscraper Repositories&amp;nbsp;&lt;/font&gt;&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font color=&quot;#000000&quot;&gt;Configure AWS Credentials with OIDC JWT Token for STS Access to Hcloud Backend Role&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font color=&quot;#000000&quot;&gt;Query SSH private keys for Hcloud servers from AWS Secrets Manager&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font color=&quot;#000000&quot;&gt;Extract Hcloud Server IP Adresses from Remote State&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font color=&quot;#000000&quot;&gt;Create SSH Config for Bastion-Host ProxyJump&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font color=&quot;#000000&quot;&gt;Prepare DEMO Workspace&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font color=&quot;#000000&quot;&gt;Secure Copy Dependencies to DEMO Instance&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font color=&quot;#000000&quot;&gt;Setup &lt;b&gt;DEMO&lt;/b&gt;&amp;nbsp;Instance /w PKI for IAM Roles Anywhere&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font color=&quot;#000000&quot;&gt;Deploy on &lt;b&gt;DEMO &lt;/b&gt;Instance via OpenSSH (optional boolean)&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font color=&quot;#000000&quot;&gt;Deploy on &lt;b&gt;BACKEND &lt;/b&gt;Instance via OpenSSH&amp;nbsp;&lt;/font&gt;&lt;span style=&quot;color: rgb(0, 0, 0);&quot;&gt;(optional boolean)&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;font color=&quot;#000000&quot;&gt;Deploy on &lt;b&gt;FRONTEND &lt;/b&gt;Instance via OpenSSH&amp;nbsp;&lt;/font&gt;&lt;span style=&quot;color: rgb(0, 0, 0);&quot;&gt;(optional boolean)&lt;/span&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="400" width="389.75" x="2745.25" y="3728" as="geometry" />
        </mxCell>
        <mxCell id="F3hjLusn7BbRF5pgiLsR-5" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fad7ac;strokeColor=#b46504;fontStyle=1;shadow=0;" value="infrastructure-deployment" vertex="1">
          <mxGeometry height="40" width="350" x="2150" y="3798" as="geometry" />
        </mxCell>
        <mxCell id="F3hjLusn7BbRF5pgiLsR-6" parent="1" style="rounded=0;html=1;align=left;verticalAlign=top;fillColor=#f5f5f5;fontColor=#333333;strokeColor=#666666;absoluteArcSize=0;shadow=0;spacing=0;whiteSpace=wrap;miterlimit=4;labelBackgroundColor=none;textShadow=0;" value="&lt;div&gt;&lt;font color=&quot;#000000&quot;&gt;&amp;nbsp; &lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;u&gt;Overview:&lt;/u&gt;&lt;/font&gt;&lt;/font&gt;&lt;/div&gt;&lt;ul&gt;&lt;li&gt;&lt;font color=&quot;#000000&quot;&gt;is manually triggered on-demand to to Deploy either the infrastructure HAProxy Loadbalancer or the Prometheus &amp;amp; Grafana Monitoring instance&amp;nbsp;&lt;/font&gt;&lt;span style=&quot;color: rgb(0, 0, 0);&quot;&gt;via Bastion-Host Instance ProxyJump&lt;/span&gt;&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;font color=&quot;#000000&quot;&gt;&amp;nbsp;&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;u&gt;Steps:&lt;/u&gt;&lt;/font&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;&lt;font color=&quot;#000000&quot;&gt;Checks out Source Code from 1) Infrastructure 2) Loadbalancer 3) Monitoring Repositories&amp;nbsp;&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font color=&quot;#000000&quot;&gt;Configure AWS Credentials with OIDC JWT Token for STS Access to Hcloud Backend Role&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font color=&quot;#000000&quot;&gt;Query SSH private keys for Hcloud servers from AWS Secrets Manager&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font color=&quot;#000000&quot;&gt;Extract Hcloud Server IP Adresses from Remote State&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font color=&quot;#000000&quot;&gt;Create SSH Config for Bastion-Host ProxyJump&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font color=&quot;#000000&quot;&gt;Deploy HAProxy &lt;b&gt;LOADBALANCER &lt;/b&gt;via OpenSSH&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font color=&quot;#000000&quot;&gt;Deploy &lt;b&gt;PROMETHEUS &amp;amp; GRAFANA&lt;/b&gt; on Monitoring Instance via OpenSSH&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" vertex="1">
