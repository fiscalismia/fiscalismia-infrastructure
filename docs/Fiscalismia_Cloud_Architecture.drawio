        <mxCell id="2hJ6fsNwjHa9k7A8V26Q-30" parent="1" style="rounded=0;whiteSpace=wrap;html=1;strokeWidth=2;strokeColor=#000066;fillColor=#dae8fc;" value="&lt;span style=&quot;forced-color-adjust: none; color: rgb(0, 0, 0); font-family: Helvetica; font-size: 11px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: center; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: nowrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;AWS&lt;/span&gt;&lt;div style=&quot;forced-color-adjust: none; color: rgb(0, 0, 0); font-family: Helvetica; font-size: 11px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: center; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: nowrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;&lt;span style=&quot;forced-color-adjust: none;&quot;&gt;trusts&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;forced-color-adjust: none; color: rgb(0, 0, 0); font-family: Helvetica; font-size: 11px; font-style: normal; font-variant-ligatures: normal; font-variant-caps: normal; font-weight: 400; letter-spacing: normal; orphans: 2; text-align: center; text-indent: 0px; text-transform: none; widows: 2; word-spacing: 0px; -webkit-text-stroke-width: 0px; white-space: nowrap; text-decoration-thickness: initial; text-decoration-style: initial; text-decoration-color: initial;&quot;&gt;&lt;span style=&quot;forced-color-adjust: none;&quot;&gt;intermediate&lt;/span&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="41.5" width="65.8" x="3130.2" y="1767" as="geometry" />
        </mxCell>
        <mxCell id="2hJ6fsNwjHa9k7A8V26Q-33" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontSize=11;fontStyle=0;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;" value="deployed on remote machine temporarily to sign and issue new leaf certs" vertex="1">
          <mxGeometry height="87" width="80" x="3380" y="1793" as="geometry" />
        </mxCell>
        <mxCell id="2hJ6fsNwjHa9k7A8V26Q-34" parent="1" style="ellipse;whiteSpace=wrap;html=1;aspect=fixed;strokeWidth=2;strokeColor=#000066;fontSize=15;fontStyle=1;fillColor=default;snapToPoint=0;fixDash=0;fontColor=#000066;" value="&lt;font style=&quot;&quot;&gt;1&lt;/font&gt;" vertex="1">
          <mxGeometry height="20" width="20" x="3149.2" y="1617.5" as="geometry" />
        </mxCell>
        <mxCell id="2hJ6fsNwjHa9k7A8V26Q-36" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontStyle=0;fontSize=14;align=left;fillColor=#f5f5f5;strokeColor=#36393D;fontColor=#333333;fontFamily=Helvetica;snapToPoint=0;fixDash=0;" value="&lt;div&gt;&lt;u&gt;&lt;span&gt;&lt;br&gt;&lt;/span&gt;&lt;/u&gt;&lt;/div&gt;&lt;u&gt;&lt;span&gt;&lt;div&gt;&lt;u&gt;&lt;span&gt;&lt;br&gt;&lt;/span&gt;&lt;/u&gt;&lt;/div&gt;Workflow&lt;/span&gt;:&lt;/u&gt;&lt;br&gt;&lt;div&gt;&lt;span&gt;&lt;b&gt;1.)&lt;/b&gt; Generate Root CA certificate and encrypted private key locally with step-cli&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span&gt;&lt;b&gt;2.)&lt;/b&gt; Generate Intermediate CA certificate signed by Root CA locally /w maxPathLen 0 (cannot create sub-CAs)&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span&gt;&lt;b&gt;3.)&lt;/b&gt;&amp;nbsp;Setup Trust Anchor from AWS to Intermediate CA&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span&gt;&lt;b&gt;4.)&lt;/b&gt; Transfer root cert, fingerpring, intermediate key, cert and pswd to Hetzner VM&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span&gt;&lt;b&gt;5.)&lt;/b&gt; Configure step-ca config files &amp;amp; directory structure&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span&gt;&lt;b&gt;6.)&lt;/b&gt; Generate JWK provisioner key pair and X.509 template&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span&gt;&lt;b&gt;7.)&lt;/b&gt; Start step-ca container with hardened security settings&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span&gt;&lt;b&gt;8.)&lt;/b&gt; Issue short-lived (1hr) end-entity certificate via step-cli against the container&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span&gt;&lt;b&gt;9.)&lt;/b&gt; Mount a RAM-only filesystem (tmpfs, swap disabled) on the Hetzner VM&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span&gt;&lt;b&gt;10.)&lt;/b&gt; Authenticate to AWS IAM Roles Anywhere /w X-509 cert obtaining temporary credentials&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span&gt;&lt;b&gt;11.)&lt;/b&gt; Retrieve secrets file from AWS Secrets Manager &amp;amp; write to RAM-backed filesystem&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span&gt;&lt;b&gt;12.)&lt;/b&gt; Start containers /w RAM tmpfs read-only volume mounted&amp;nbsp;&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;span&gt;&lt;b&gt;13.)&lt;/b&gt; After container health check, shred and delete the secrets for the postgres, backend and webscraper containers, secrets only remain in application memory&lt;/span&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;14.)&lt;/b&gt;&amp;nbsp;Shred and delete the entire step-ca setup including all certificates and keys, they were only needed to query short-lived AWS credentials once during deployment&lt;/div&gt;" vertex="1">
          <mxGeometry height="769" width="250" x="3640" y="1521" as="geometry" />
        </mxCell>
        <mxCell id="2hJ6fsNwjHa9k7A8V26Q-37" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fontStyle=2;fontSize=16;align=center;fillColor=#BAC8D3;strokeColor=#23445D;fontFamily=Helvetica;labelBorderColor=none;snapToPoint=0;fixDash=0;" value="Setup Public Key Infrastructure" vertex="1">
