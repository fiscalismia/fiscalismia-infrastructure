        <mxCell id="xqXAjq9A-HITpdVLmNYo-27" parent="xqXAjq9A-HITpdVLmNYo-24" style="image;aspect=fixed;html=1;points=[];align=center;fontSize=12;image=img/lib/azure2/databases/Azure_Database_PostgreSQL_Server.svg;fontFamily=Helvetica;snapToPoint=0;fixDash=0;" value="neondb&lt;br&gt;managed&lt;br&gt;postgres" vertex="1">
