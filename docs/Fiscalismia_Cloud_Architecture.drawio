          </mxCell>
        </UserObject>
        <mxCell id="LnlJB3bpqqkoOhL225ai-11" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d0cee2;strokeColor=#56517e;fontStyle=1;shadow=0;" value="destroy-aws-and-hcloud" vertex="1">
          <mxGeometry height="40" width="321" x="2176" y="3527" as="geometry" />
        </mxCell>
        <mxCell id="LnlJB3bpqqkoOhL225ai-12" parent="1" style="rounded=0;html=1;align=left;verticalAlign=top;fillColor=#f5f5f5;fontColor=#333333;strokeColor=#666666;absoluteArcSize=0;shadow=0;spacing=0;whiteSpace=wrap;miterlimit=4;labelBackgroundColor=none;textShadow=0;" value="&lt;ul&gt;&lt;li&gt;&lt;font color=&quot;#000000&quot;&gt;is invoked via authenticated webhook&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font color=&quot;#000000&quot;&gt;dependent on the flags destroy_hcloud | destroy_aws it destroys either aws, hcloud, or both&lt;br&gt;&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font color=&quot;#000000&quot;&gt;Queries SSH public keys for Hcloud servers from AWS Secrets Manager because hcloud terraform fails unless all variables are present&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font color=&quot;#000000&quot;&gt;Destroys all dynamic (non-persistent) AWS resources if&amp;nbsp;&lt;/font&gt;&lt;span style=&quot;color: rgb(0, 0, 0);&quot;&gt;destroy_aws&amp;nbsp;== true&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;color: rgb(0, 0, 0);&quot;&gt;Destroys all Hetzner resources if&amp;nbsp;&lt;/span&gt;&lt;span style=&quot;color: rgb(0, 0, 0);&quot;&gt;destroy_hcloud&amp;nbsp;== true&lt;/span&gt;&lt;/li&gt;&lt;/ul&gt;" vertex="1">
          <mxGeometry height="171" width="321" x="2176" y="3567" as="geometry" />
        </mxCell>
