        </UserObject>
        <mxCell id="2dqsXh7Py2JDM5GBmdY1-14" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#fad7ac;strokeColor=#b46504;fontStyle=1;shadow=0;" value="fetch-and-validate-tls-certs" vertex="1">
          <mxGeometry height="40" width="389.75" x="2745.25" y="3278" as="geometry" />
        </mxCell>
        <mxCell id="2dqsXh7Py2JDM5GBmdY1-15" parent="1" style="rounded=0;html=1;align=left;verticalAlign=top;fillColor=#f5f5f5;fontColor=#333333;strokeColor=#666666;absoluteArcSize=0;shadow=0;spacing=0;whiteSpace=wrap;miterlimit=4;labelBackgroundColor=none;textShadow=0;" value="&lt;div&gt;&lt;font color=&quot;#000000&quot;&gt;&amp;nbsp; &lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;u&gt;Overview:&lt;/u&gt;&lt;/font&gt;&lt;/font&gt;&lt;/div&gt;&lt;ul&gt;&lt;li&gt;&lt;font color=&quot;#000000&quot;&gt;is manually triggered on-demand to push scoped down IAM Access Key Credentials onto private Hcloud Instances. These credentials only have access to Route53 and DNS entries in the hosted zone for fiscalismia.com&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font color=&quot;#000000&quot;&gt;Its purpose is to use the certbot-route53 plugin to validate TLS certificates via dns-01 challenges (adding temporary TXT Records to the Route53 hosted zone)&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;&lt;div&gt;&lt;font color=&quot;#000000&quot;&gt;&amp;nbsp;&lt;font style=&quot;font-size: 14px;&quot;&gt;&lt;u&gt;Steps:&lt;/u&gt;&lt;/font&gt;&lt;/font&gt;&lt;/div&gt;&lt;div&gt;&lt;ul&gt;&lt;li&gt;&lt;font color=&quot;#000000&quot;&gt;&lt;font&gt;Checks out Source Code&lt;/font&gt;&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font color=&quot;#000000&quot;&gt;&lt;font style=&quot;&quot;&gt;Configure AWS Credentials with OIDC JWT Token for STS Access to Hcloud Backend Role&lt;/font&gt;&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font color=&quot;#000000&quot;&gt;&lt;font style=&quot;&quot;&gt;Query SSH private keys for Hcloud servers from AWS Secrets Manager&lt;/font&gt;&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font color=&quot;#000000&quot;&gt;&lt;font style=&quot;&quot;&gt;Extract Hcloud Server IP Adresses from Remote State&lt;/font&gt;&lt;/font&gt;&lt;/li&gt;&lt;li&gt;&lt;font color=&quot;#000000&quot;&gt;&lt;font style=&quot;&quot;&gt;Create SSH Config for Bastion-Host ProxyJump&lt;/font&gt;&lt;/font&gt;&lt;/li&gt;&lt;li&gt;Copy AWS Credentials to Target Instances&lt;/li&gt;&lt;li&gt;Run certbot certificate request and validation script&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="330" width="389.75" x="2745.25" y="3318" as="geometry" />
        </mxCell>
