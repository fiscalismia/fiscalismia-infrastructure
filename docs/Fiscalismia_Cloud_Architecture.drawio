        <mxCell id="xqXAjq9A-HITpdVLmNYo-28" parent="xqXAjq9A-HITpdVLmNYo-24" style="rounded=0;whiteSpace=wrap;html=1;fontStyle=0;fontSize=14;align=left;fillColor=#f5f5f5;strokeColor=#666666;fontColor=#333333;fontFamily=Helvetica;snapToPoint=0;fixDash=0;" value="&lt;u&gt;&lt;b&gt;Workflow&lt;/b&gt;:&lt;/u&gt;&lt;br&gt;&lt;div&gt;&lt;b&gt;1.) &lt;/b&gt;&lt;b&gt;&lt;/b&gt;Frontend Upload Img btn press&lt;/div&gt;&lt;div&gt;&lt;b&gt;2.) &lt;/b&gt;A Record forwards to Hetzner LB&lt;br&gt;&lt;b&gt;3.) &lt;/b&gt;Frontend sends request payload to backend Rest API&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;b&gt;4.) &lt;/b&gt;Backend Rest API binary encodes image and sends request payload to HTTP API Gateway&lt;/div&gt;&lt;b&gt;5.) &lt;/b&gt;API GW forwards request payload to NodeJS img processing Lambda&lt;br&gt;&lt;b&gt;6.) &lt;/b&gt;Lambda scales down image and sends image to S3 bucket&lt;br&gt;&lt;div&gt;&lt;b&gt;7.) &lt;/b&gt;Lambda receives&amp;nbsp;s3 object url&lt;/div&gt;&lt;div&gt;&lt;b&gt;8.) &lt;/b&gt;API GW receives response from Lambda&lt;br&gt;&lt;/div&gt;&lt;b&gt;9.) &lt;/b&gt;Backend Rest API receives response from API GW&lt;br&gt;&lt;div&gt;&lt;b&gt;10.) &lt;/b&gt;Backend sends INSERT img url statement to neon psql db&lt;/div&gt;&lt;div&gt;&lt;b&gt;11.) &lt;/b&gt;Backend responds to img upload btn press with persisted img url response from backend&lt;br&gt;&lt;b&gt;12.) &lt;/b&gt;Frontend renders downscaled img from s3 and displays it to user&lt;br&gt;&lt;/div&gt;" vertex="1">
          <mxGeometry height="420" width="240" x="-90" y="10" as="geometry" />
        </mxCell>
